# Neon DB connection string (z panelu Neon → Connection Details → Pooled connection)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Token admina — wymyśl długie losowe hasło, np. openssl rand -hex 32
ADMIN_TOKEN=zmien_to_na_dlugie_losowe_haslo_min_32_znaki

# Gmail — adres i App Password (Google → Konto → Bezpieczeństwo → Hasła do aplikacji)
GMAIL_USER=twoj@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Port (Render ustawia automatycznie)
PORT=3000
